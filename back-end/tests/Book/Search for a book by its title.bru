meta {
  name: Search for a book by its title
  type: http
  seq: 1
  tags: [
    Book
    Search
  ]
}

get {
  url: {{baseUrl}}/search/book/:title
  body: none
  auth: inherit
}

params:query {
  ~page: 
}

params:path {
  title: harry pothead
}

docs {
  Searches for a book by its title, using the Google Books API to retrieve results. Results are limited to 10 matching books at a time. Use the `page` query to get more results (e.g., `page=1`, the default, will show the top 10 matches, `page=2` shows results 11-20, and so on).
}

example {
  name: 200 Response
  description: Matching books were found.
  
  request: {
    url: {{baseUrl}}/search/book/:title
    method: GET
    mode: none
    params:query: {
      ~page: 
    }
  
    params:path: {
      title: 
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        [
          {
            "id": "",
            "authors": [],
            "rating": 0,
            "categories": [],
            "description": "",
            "image": "",
            "title": "",
            "publishDate": ""
          }
        ]
      '''
    }
  }
}

example {
  name: 400 Response
  description: The `page` query wasn't an integer.
  
  request: {
    url: {{baseUrl}}/search/book/:title
    method: GET
    mode: none
    params:query: {
      ~page: asdf
    }
  
    params:path: {
      title: 
    }
  }
  
  response: {
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}

example {
  name: 404 Response
  description: No matching books were found.
  
  request: {
    url: {{baseUrl}}/search/book/kamslkasmdfasdf
    method: GET
    mode: none
    params:query: {
      ~page: 
    }
  }
  
  response: {
    status: {
      code: 404
      text: Not Found
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}
