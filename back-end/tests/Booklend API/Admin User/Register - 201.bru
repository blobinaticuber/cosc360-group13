meta {
  name: Register - 201
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/admin/user
  body: json
  auth: none
}

body:json {
  {
    "name": "{{testUserName}}",
    "email": "{{testUserEmail}}",
    "password": "{{testUserPassword}}",
    "adminKey": "{{adminKey}}"
  }
  
}

assert {
  res.status: eq 201
}
