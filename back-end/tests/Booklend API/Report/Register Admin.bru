meta {
  name: Register Admin
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/admin/user
  body: json
  auth: none
}

body:json {
  {
    "name": "admin{{testUserName}}",
    "email": "admin{{testUserEmail}}",
    "password": "{{testUserPassword}}",
    "adminKey": "{{adminKey}}"
  }
  
}

assert {
  res.status: eq 201
}
