meta {
  name: Register A
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/user
  body: json
  auth: none
}

body:json {
  {
    "name": "a{{testUserName}}",
    "email": "a{{testUserEmail}}",
    "password": "{{testUserPassword}}"
  }
  
}

assert {
  res.status: eq 201
}

script:post-response {
  bru.setVar("aId", res.body.id)
  
}
