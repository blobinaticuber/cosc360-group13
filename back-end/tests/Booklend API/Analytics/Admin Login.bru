meta {
  name: Admin Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/admin/user/session
  body: json
  auth: inherit
}

body:json {
  {
    "email": "{{testData.admins[0].email}}",
    "password": "{{testData.admins[0].password}}"
  }
}

assert {
  res.status: eq 200
}

settings {
  encodeUrl: true
  timeout: 0
}
