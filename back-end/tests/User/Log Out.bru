delete {
  url: {{baseUrl}}/user/session
  body: none
  auth: inherit
}

docs {
  Log out (delete a session).
}

example {
  name: 200 Response
  description: The user is now logged out.
  
  request: {
    url: {{baseUrl}}/user/session
    method: DELETE
    mode: none
  }
  
  response: {
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}

example {
  name: 401 Response
  description: There isn't a user to log out.
  
  request: {
    url: {{baseUrl}}/user/session
    method: DELETE
    mode: none
  }
  
  response: {
    status: {
      code: 401
      text: Unauthorized
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}
