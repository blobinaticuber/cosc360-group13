}

params:query {
  ~id: 
  ~name: 
}

docs {
  Get public information about a user.
}

example {
  name: 200 Response
  description: User details successfully retrieved.
  
  request: {
    url: {{baseUrl}}/user
    method: GET
    mode: none
    params:query: {
      ~id: 
      ~name: 
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "id": "",
          "name": "",
          "profilePicture": ""
        }
      '''
    }
  }
}

example {
  name: 404 Response
  description: No matching user found.
  
  request: {
