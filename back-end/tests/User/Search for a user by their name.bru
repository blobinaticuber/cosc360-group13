meta {
  name: Search for a user by their name
  type: http
  seq: 6
  tags: [
    User
    Search
  ]
}

get {
  url: {{baseUrl}}/search/user/:name
  body: none
  auth: inherit
}

params:query {
  ~page: 
}

params:path {
  name: 
}

docs {
  Search for a user by their name. The response will include any user whose name includes the {name} parameter as a substring.
}

example {
  name: 200 Response
  description: The matching users were found.
  
  request: {
    url: {{baseUrl}}/search/user/:name
    method: GET
    mode: none
    params:query: {
      ~page: 
    }
  
    params:path: {
      name: 
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        [
          {
            "id": "",
            "name": "",
            "profilePicture": ""
          }
        ]
      '''
    }
  }
}

example {
  name: 400 Response
  description: The `page` query wasn't an integer.
  
  request: {
    url: {{baseUrl}}/search/user/:name
    method: GET
    mode: none
    params:query: {
      ~page: 
    }
  
    params:path: {
      name: 
    }
  }
  
  response: {
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}

example {
  name: 404 Response
  description: No matching users were found.
  
  request: {
    url: {{baseUrl}}/search/user/:name
    method: GET
    mode: none
    params:query: {
      ~page: 
    }
  
    params:path: {
      name: 
    }
  }
  
  response: {
    status: {
      code: 404
      text: Not Found
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}
