meta {
  name: Delete the current user
  type: http
  seq: 3
  tags: [
    User
  ]
}

delete {
  url: {{baseUrl}}/user
  body: none
  auth: inherit
}

docs {
  Delete the user that is currently logged in.
}

example {
  name: 200 Response
  description: The user was deleted.
  
  request: {
    url: {{baseUrl}}/user
    method: DELETE
    mode: none
  }
  
  response: {
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}

example {
  name: 401 Response
  description: There isn't an authenticated user to delete.
  
  request: {
    url: {{baseUrl}}/user
    method: DELETE
    mode: none
  }
  
  response: {
    status: {
      code: 401
      text: Unauthorized
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}
