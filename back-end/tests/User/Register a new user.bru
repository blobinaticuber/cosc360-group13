meta {
  name: Register a new user
  type: http
  seq: 1
  tags: [
    User
  ]
}

post {
  url: {{baseUrl}}/user
  body: json
  auth: inherit
}

body:json {
  {
    "name": "",
    "email": "",
    "password": "",
    "profilePicture": ""
  }
}

docs {
  Register a new user.
}

example {
  name: 201 Response
  description: User registered successfully.
  
  request: {
    url: {{baseUrl}}/user
    method: POST
    mode: json
    body:json: {
      {
        "name": "",
        "email": "",
        "password": "",
        "profilePicture": ""
      }
    }
  }
  
  response: {
    status: {
      code: 201
      text: Created
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}

example {
  name: 400 Response
  description: Invalid request body.
  
  request: {
    url: {{baseUrl}}/user
    method: POST
    mode: json
    body:json: {
      {
        "name": "",
        "email": "",
        "password": "",
        "profilePicture": ""
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
          "type": "invalid body",
          "expected": "",
          "received": ""
        }
      '''
    }
  }
}

example {
  name: 409 Response
  description: Conflicting field (email or password).
  
  request: {
    url: {{baseUrl}}/user
    method: POST
    mode: json
    body:json: {
      {
        "name": "",
        "email": "",
        "password": "",
        "profilePicture": ""
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 409
      text: Conflict
    }
  
    body: {
      type: json
      content: '''
        {
          "type": "conflict",
          "conflicts": {}
        }
      '''
    }
  }
}
