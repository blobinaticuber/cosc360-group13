meta {
  name: Create a listing
  type: http
  seq: 1
  tags: [
    Listing
  ]
}

post {
  url: {{baseUrl}}/listing
  body: json
  auth: inherit
}

body:json {
  {
    "book": ""
  }
}

docs {
  Create a new listing under whichever user is currently logged in. The `book` field is the ID of the book as it appears in the Google Books API. To get such an ID, you should use the book search endpoint.
}

example {
  name: 201 Response
  description: Listing created successfully.
  
  request: {
    url: {{baseUrl}}/listing
    method: POST
    mode: json
    body:json: {
      {
        "book": ""
      }
    }
  }
  
  response: {
    status: {
      code: 201
      text: Created
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}

example {
  name: 400 Response
  description: Invalid request body.
  
  request: {
    url: {{baseUrl}}/listing
    method: POST
    mode: json
    body:json: {
      {
        "book": ""
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
          "type": "invalid body",
          "expected": "",
          "received": ""
        }
      '''
    }
  }
}

example {
  name: 401 Response
  description: Request made by an unrecognized user.
  
  request: {
    url: {{baseUrl}}/listing
    method: POST
    mode: json
    body:json: {
      {
        "book": ""
      }
    }
  }
  
  response: {
    status: {
      code: 401
      text: Unauthorized
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}

example {
  name: 404 Response
  description: The book ID given was not recognized.
  
  request: {
    url: {{baseUrl}}/listing
    method: POST
    mode: json
    body:json: {
      {
        "book": ""
      }
    }
  }
  
  response: {
    status: {
      code: 404
      text: Not Found
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}
